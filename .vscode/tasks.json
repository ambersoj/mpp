{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Build MPP",
        "type": "shell",
        "command": "/usr/bin/g++",
        "args": [
          "-g",
          "mpp.cpp",
          "-o", "mpp",
          "-I/usr/local/mpp/chatgptmpp/vscmpp/lib/include",
          "-L/usr/local/mpp/chatgptmpp/vscmpp/lib",
          "-lnet",
          "-lpcap"
        ],
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "problemMatcher": ["$gcc"],
        "detail": "Compiles the mpp.cpp file using g++ with libnet and libpcap."
      }
    ]
  }
  